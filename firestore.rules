rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Configuración de cada planta (Juárez, Monclova, etc.)
    match /plants/{plantId} {
      // Las maquilas deben poder leer la configuración de la planta (nombres, logos habilitados, etc.)
      allow read: if true;
      // Solo el equipo de administración de Grupo AVE autenticado puede modificar las plantas
      allow write: if request.auth != null;
    }
    
    // Menús Semanales
    match /menus/{menuId} {
      // Cualquier maquila puede consultar el menú de su planta
      allow read: if true;
      // Solo el equipo de administración de Grupo AVE autenticado puede crear/editar menús
      allow write: if request.auth != null;
    }
    
    // Aprobaciones y firmas
    match /approvals/{approvalId} {
      // La maquila crea la aprobación de su menú una vez que digita su contraseña maestra
      allow create: if true;
      // Solo los administradores autenticados de Grupo AVE pueden ver las alertas y auditorías
      allow read: if request.auth != null;
      // Las aprobaciones firmadas son inmutables por seguridad (no se editan ni se eliminan)
      allow update, delete: if false;
    }
  }
}
